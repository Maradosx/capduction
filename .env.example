# ═════════════════════════════════════════════════════════════════════
#  CAPDUCTION — ENVIRONMENT CONFIGURATION
#  Copy to .env.local and fill what you need.
#  EVERY block is OPTIONAL — app runs in DEMO MODE with no env at all.
# ═════════════════════════════════════════════════════════════════════

# ─── 1. AI CORE ──────────────────────────────────────────────────────
# OpenAI is the brain. Without it, all 3 studios return Thai mock data
# so you can preview the UI without spending tokens.
# Get a key: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-yourapikeyhere

# ─── 2. BRANDING (optional) ──────────────────────────────────────────
NEXT_PUBLIC_APP_NAME="Capduction"
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── 3. SUPABASE (Auth + Database) ───────────────────────────────────
# Without these, /dashboard runs in demo mode (no auth, no persistence).
# Create a project: https://supabase.com  →  Settings → API
# Then run migrations 001 → 004 in the SQL editor.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here

# Service role key — needed by Stripe webhook to insert billing_events
# (which has RLS policy `WITH CHECK (false)` blocking client-side inserts).
# Found in: Supabase → Settings → API → service_role (KEEP SECRET, server-only)
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# ─── 4. STRIPE BILLING ───────────────────────────────────────────────
# Without these, the Studio/Agency CTAs on /pricing redirect to
# /pricing?error=stripe_not_configured (no crash).
#
# Setup: https://dashboard.stripe.com
#   1. Create 2 Products with monthly recurring prices:
#      - Capduction Studio  → ฿349/mo  → copy the Price ID
#      - Capduction Agency  → ฿1,290/mo → copy the Price ID
#   2. Webhook endpoint: POST https://your-domain/api/webhooks/stripe
#      Subscribe to: checkout.session.completed,
#                    customer.subscription.updated,
#                    customer.subscription.deleted,
#                    invoice.paid
#      Copy the signing secret.
STRIPE_SECRET_KEY=sk_test_REPLACE_ME
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_REPLACE_ME
STRIPE_WEBHOOK_SECRET=whsec_REPLACE_ME
STRIPE_STUDIO_PRICE_ID=price_REPLACE_ME
STRIPE_AGENCY_PRICE_ID=price_REPLACE_ME

# ─── 5. UPSTASH REDIS (Rate Limiting) ────────────────────────────────
# Without these, generation APIs have no rate limit.
# Free tier is plenty: https://upstash.com → Create Redis → REST API
UPSTASH_REDIS_REST_URL=https://your-upstash-url.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_upstash_token_here
